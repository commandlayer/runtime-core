{
  "name": "@commandlayer/runtime-core",
  "version": "1.1.0",
  "description": "Core contract primitives for CommandLayer v1.1.0 runtimes",
  "type": "module",
  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js"
    },
    "./receipt-v1": {
      "types": "./dist/receipt-v1.d.ts",
      "import": "./dist/receipt-v1.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "test": "npm run build && node --test dist/test/*.test.js tests/*.test.mjs",
    "prepack": "npm run clean && npm run build"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "ethers": "^6.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "typescript": "^5.8.2"
  }
}
